# Environment (dev | prod). Drives which Turso DB is used.
NUXT_APP_ENV=dev

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Turso — prod
TURSO_PROD_DATABASE_URL=
TURSO_PROD_AUTH_TOKEN=

# Turso — dev
TURSO_DEV_DATABASE_URL=
TURSO_DEV_AUTH_TOKEN=

# GitHub OAuth — create an app at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
